SPRING_PROFILES_ACTIVE=prod
APP_SITE_BASE_URL=https://kitchenrulehub.com
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=replace-with-strong-password
APP_ATTRIBUTION_LOG_DIR=/var/lib/kitchenrulehub/attribution
APP_LEAD_LOG_DIR=/var/lib/kitchenrulehub/leads
APP_OPS_AUDIT_DIR=/var/lib/kitchenrulehub/ops
APP_FRESHNESS_AUDIT_ENABLED=true
APP_FRESHNESS_AUDIT_CRON=0 15 6 * * *
APP_FRESHNESS_AUDIT_ZONE=UTC
JAVA_OPTS=-Xms256m -Xmx768m
